# ==========================================================================
# 1Health Pharmacy Chatbot — backend environment
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ==========================================================================

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_INTENT_MODEL=gpt-4o-mini      # cheap classifier for idle-state intent
OPENAI_VISION_MODEL=gpt-4o           # prescription OCR (vision)

# ---- Supabase ----
SUPABASE_URL=https://mzajcuhbfufyhgafoyax.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here
SUPABASE_PRESCRIPTION_BUCKET=prescriptions

# ---- Razorpay (test mode for the demo) ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-here
# Set this to the "Webhook Secret" you configure in the Razorpay dashboard.
# Used to verify the X-Razorpay-Signature header on incoming webhooks.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret-here

# Optional shared secret for the Supabase order-status Database Webhook.
# If set, add a custom header `x-webhook-secret: <this value>` to the webhook in
# the Supabase dashboard. Leave blank to accept unauthenticated webhook calls.
SUPABASE_WEBHOOK_SECRET=

# ---- Redis (pub/sub + in-flight state) ----
REDIS_URL=redis://localhost:6379

# ---- Google Maps (optional, skipped for demo — pincode lookup used instead) ----
GOOGLE_MAPS_KEY=

# ---- App / server ----
APP_HOST=0.0.0.0
APP_PORT=8000
# Comma-separated list of origins allowed to call the API / open the WebSocket.
# Include your local Vite dev server and the production site.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://1healthpharmacy.in

# Public base URL the backend is reachable at (used to build the Razorpay
# webhook callback URL). For local demo this is your ngrok https URL.
PUBLIC_BASE_URL=http://localhost:8000

# ---- Business rules (overridable without touching code) ----
DELIVERY_MIN_ORDER=100               # min order value for PRESCRIPTION delivery (INR)
DELIVERY_CHARGE_COD=40               # COD delivery charge (INR)
DELIVERY_CHARGE_ONLINE=20            # online-payment delivery charge (INR)
